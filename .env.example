# Application
APP_NAME=Campus Foodie API
ENVIRONMENT=development
SECRET_KEY=replace-with-a-long-random-value
AUTO_SEED=true
USER_WEB_ORIGIN=http://127.0.0.1:7991
ADMIN_WEB_ORIGIN=http://127.0.0.1:7992
API_BASE_URL=http://127.0.0.1:7993
CORS_ORIGINS=http://localhost:7991,http://localhost:7992,http://127.0.0.1:7991,http://127.0.0.1:7992
USER_ACCESS_TOKEN_MINUTES=60
REFRESH_TOKEN_DAYS=30
GUEST_TOKEN_DAYS=90
ACCOUNT_TOKEN_MINUTES=30
OAUTH_PROVIDERS=

# Database and background services
# 开箱即用的本地配置；Docker Compose 会为 API 覆盖为 PostgreSQL。
DATABASE_URL=sqlite:///./runtime/campus_food.db
# PostgreSQL 示例：postgresql+psycopg://campus_foodie:campus_foodie@localhost:5432/campus_foodie
REDIS_URL=
UPLOAD_DIR=./runtime/uploads
MAX_UPLOAD_BYTES=10485760

# Mail
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=false
MAIL_FROM=Campus Foodie <no-reply@campus-foodie.local>

# DeepSeek (leave empty to use deterministic recommendation and manual review fallback)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT_SECONDS=8
