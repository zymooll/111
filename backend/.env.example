APP_NAME=Campus Foodie API
ENVIRONMENT=development
DATABASE_URL=sqlite:///./runtime/campus_food.db
SECRET_KEY=replace-with-a-long-random-secret
USER_ACCESS_TOKEN_MINUTES=60
REFRESH_TOKEN_DAYS=30
GUEST_TOKEN_DAYS=90
AUTO_SEED=true
CORS_ORIGINS=http://localhost:7991,http://localhost:7992,http://127.0.0.1:7991,http://127.0.0.1:7992
UPLOAD_DIR=./runtime/uploads
MAX_UPLOAD_BYTES=10485760
OAUTH_PROVIDERS=
USER_WEB_ORIGIN=http://127.0.0.1:7991
ACCOUNT_TOKEN_MINUTES=30
SMTP_HOST=
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=false
MAIL_FROM=Campus Foodie <no-reply@campus-foodie.local>

# Optional production integrations
REDIS_URL=
AMAP_WEB_SERVICE_KEY=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT_SECONDS=4
